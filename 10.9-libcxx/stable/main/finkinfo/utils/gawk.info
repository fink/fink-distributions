Package: gawk
Version: 5.4.0

Revision: 2
Maintainer: None <fink-devel@lists.sourceforge.net>
BuildDepends: <<
	fink (>= 0.32),
	fink-package-precedence,
	gettext-bin,
	gettext-tools,
	gmp5,
	libgettext8-dev,
	libiconv-dev,
	libmpfr6,
	readline8
<<

Depends: <<
	gmp5-shlibs,
	libgettext8-shlibs,
	libiconv,
	libmpfr6-shlibs,
	readline8-shlibs
<<

Source: mirror:gnu:%n/%n-%v.tar.xz
Source-Checksum: SHA256(3dd430f0cd3b4428c6c3f6afc021b9cd3c1f8c93f7a688dc268ca428a90b4ac1)
PatchFile: %n.patch
PatchFile-MD5: 4f0afc2bbff955cd4dc3bd37ac8d94c6

ConfigureParams: <<
	--libexecdir=%p/lib \
	ac_cv_prog_AWK=awk
<<
InstallScript: <<
	fink-package-precedence .
	make install DESTDIR=%d AM_UPDATE_INFO_DIR=no
<<
DocFiles: AUTHORS COPYING README NEWS POSIX.STD
InfoDocs: gawk.info gawkinet.info
InfoTest: TestScript: make -j1 -k check || exit 2

#
Description: The Awk processing language, GNU edition
DescDetail: <<
Awk is a sophisticated text processing language commonly used in shell
scripts. Note that many people actually prefer mawk over gawk because
of speed.
<<

