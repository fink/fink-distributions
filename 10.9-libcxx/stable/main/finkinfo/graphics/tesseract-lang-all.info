SplitOff1000: <<
	Package: tesseract-lang-documentation
	InstallScript: <<
	#!/bin/sh -ev
		# packaging safety
		remainder=`find %I/share/tessdata -type f`
		if [[ -n "$remainder" ]]; then
			echo "Untracked language files remaining!"
			echo $remainder
			exit 1
		fi
	<<
	DocFiles: LICENSE README.md
