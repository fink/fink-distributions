InstallScript: <<
	mkdir -p %i/share/tessdata/5/tessdata
	install -m 0644 *.traineddata %i/share/tessdata/5/tessdata
	mkdir -p %i/share/tessdata/5/tessdata/script
	install -m 0644 script/*.traineddata %i/share/tessdata/5/tessdata/script
	mkdir -p %i/share/doc/installed-packages
	touch %i/share/doc/installed-packages/%n
<<
