Package: libtesseract5-shlibs
Version: 5.5.2
Revision: 1
Source: https://github.com/tesseract-ocr/tesseract/archive/refs/tags/%v.tar.gz
SourceRename: tesseract-%v.tar.gz
Source-Checksum: SHA256(6235ea0dae45ea137f59c09320406f5888383741924d98855bd2ce0d16b54f21)
Depends: <<
	libarchive31-shlibs,
	libcurl4-shlibs,
	libleptonica6-shlibs
<<
# pango/cairo only needed for training tools, which we cannot build at
# this time, so no deps needed and ignoring autoconf tests for them
BuildDepends: <<
	autoconf2.6,
	automake1.15,
	libarchive31,
	libcurl4,
	libleptonica6-dev,
	libtool2,
	pkgconfig
<<
GCC: 4.0
# Fix -I ordering. It's a bug in several CPU-specific options also,
# but possibly none of them apply to fink platforms.
#
# Building the training tools requires pango >= 1.38.0 and there is no
# --disable flag for it, so patch it out to be deterministic in the
# future.
#
# Fix FTBFS:
#  https://github.com/tesseract-ocr/tesseract/issues/3918
#  https://github.com/tesseract-ocr/tesseract/issues/4552
PatchFile: %n.patch
PatchFile-MD5: 4f5f2de07b37e1ec66c4404378a76e27
PatchScript: <<
	%{default_script}
	perl -pi -e 's/(-framework)\s+(\S+)/-Wl,\1,\2/g' configure.ac
<<
# building the docs fail with asciidoc errors
ConfigureParams: <<
	--disable-static \
	ac_cv_prog_have_brew=false \
	--disable-doc \
	--disable-silent-rules
<<
CompileScript: <<
	./autogen.sh
	./configure %c
	make NOUNDEFINED=-no-undefined
<<
Shlibs: %p/lib/libtesseract.5.dylib 6.0.0 %n (>= 5.5.2-1)
DocFiles: AUTHORS ChangeLog CITATIONS.bib CONTRIBUTING.md LICENSE README.MD
SplitOff: <<
	Package: libtesseract5-dev
	Depends: %N (= %v-%r)
	BuildDependsOnly: true
	Files: <<
		include
		lib/libtesseract.{dylib,la}
		lib/pkgconfig
	<<
	DocFiles: AUTHORS ChangeLog CITATIONS.bib CONTRIBUTING.md LICENSE README.MD
<<
SplitOff2: <<
	Package: tesseract
	Depends: <<
		%N (>= %v-%r),
		libarchive31-shlibs,
		libcurl4-shlibs,
		libleptonica6-shlibs
	<<
	Files: bin
	DocFiles: AUTHORS ChangeLog CITATIONS.bib CONTRIBUTING.md LICENSE README.MD
<<
SplitOff3: <<
	Package: tesseract-data
	Files: share/tessdata
	DocFiles: AUTHORS ChangeLog CITATIONS.bib CONTRIBUTING.md LICENSE README.MD
<<
Description: Open source OCR engine
DescUsage: <<
	You will need to install at least one language-specific
	dataset to make this useful.
<<
Homepage: https://github.com/tesseract-ocr/tesseract
License: BSD
Maintainer: Daniel Macks <dmacks@netspace.org>
