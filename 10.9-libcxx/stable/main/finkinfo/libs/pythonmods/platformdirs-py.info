Info2: <<
Package: platformdirs-py%type_pkg[python]
Version: 4.3.1
Revision: 1
Type: python (3.8 3.9 3.10)
Description: Determines appropriate platform-specific dirs
License: BSD
Maintainer: None <fink-devel@lists.sourceforge.net>
BuildDepends: <<
	bootstrap-modules-py%type_pkg[python] (>= 20260715),
	hatch-vcs-py%type_pkg[python] (>= 0.4),
	hatchling-py%type_pkg[python] (>= 1.18)
<<
Depends: <<
	python%type_pkg[python]
<<
Source: https://files.pythonhosted.org/packages/source/p/platformdirs/platformdirs-%v.tar.gz
Source-Checksum: SHA256(63b79589009fa8159973601dd4563143396b35c5f93a58b36f9049ff046949b1)
CompileScript: <<
	PYTHONPATH=%p/share/bootstrap-modules-python%type_pkg[python] %p/bin/python%type_raw[python] -m build --wheel --no-isolation --skip-dependency-check
<<
InfoTest: <<
	TestDepends: <<
		appdirs-py%type_pkg[python] (>= 1.4.4),
		covdefaults-py%type_pkg[python] (>= 2.3),
		pytest-py%type_pkg[python] (>= 7.4.3),
		pytest-cov-py%type_pkg[python] (>= 4.1),
		pytest-mock-py%type_pkg[python] (>= 3.12)
	<<
	TestScript: PYTHONPATH=%b/src: %p/bin/python%type_raw[python] -m pytest -vv || exit 2
<<
InstallScript: <<
	PYTHONPATH=%p/share/bootstrap-modules-python%type_pkg[python] %p/bin/python%type_raw[python] -m installer --destdir %d dist/*.whl
<<
DocFiles: LICENSE README.rst
DescDetail: <<
When writing desktop application, finding the right location to store
user data and configuration varies per platform. Even for
single-platform apps, there may by plenty of nuances in figuring out
the right location.
<<
Homepage: https://github.com/tox-dev/platformdirs
<<
