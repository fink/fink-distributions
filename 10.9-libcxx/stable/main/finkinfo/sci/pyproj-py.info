InstallScript: <<
	#!/bin/bash -ev
	export PROJ_DIR=%p
	PYTHONPATH=%p/share/bootstrap-modules-python%type_pkg[python] %p/bin/python%type_raw[python] -m installer --destdir %d dist/*.whl
	mv %i/bin/pyproj %i/bin/pyproj-py%type_pkg[python]
<<
PostInstScript: <<
	update-alternatives --install %p/bin/pyproj pyproj %p/bin/pyproj-py%type_pkg[python] %type_pkg[python]
<<

PreRmScript: <<
if [ $1 != "upgrade" ]; then
	update-alternatives --remove pyproj %p/bin/pyproj-py%type_pkg[python]
fi
<<
